// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// =============================================
// FEATURE - Lưu thông tin tính năng AI + Prompt
// =============================================
model Feature {
  id          String   @id @default(cuid())
  slug        String   @unique  // "swap_shirt", "to_anime", ...
  name        String            // Tên hiển thị: "Thay áo", "Ảnh thật → Anime"
  nameEn      String            // English name
  description String?           // Mô tả tính năng
  prompt      String   @db.Text // Prompt gốc gửi lên API
  category    String            // "fashion", "creative", "photo_edit"
  imageCount  Int      @default(1) // Số ảnh cần upload (1 hoặc 2)
  sortOrder   Int      @default(0)
  isActive    Boolean  @default(true)
  creditCost  Int      @default(1)  // Số credit tốn khi dùng
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  jobs        Job[]

  @@index([category])
  @@index([slug])
}

// =============================================
// USER - Người dùng
// =============================================
model User {
  id               String    @id @default(cuid())
  name             String?
  email            String    @unique
  emailVerified    DateTime?
  image            String?
  password         String?   // null for OAuth users, bcrypt hash for credentials users
  role             String    @default("USER") // "USER" | "STAFF" | "ADMIN"
  credits          Int       @default(10)
  plan             String    @default("free") // "free", "starter", "pro", "max"
  planExpiresAt    DateTime?                  // Ngày hết hạn gói tháng (null = free)
  stripeCustomerId String?   @unique          // Stripe customer ID
  isBanned         Boolean   @default(false)  // Admin có thể ban user
  banReason        String?                    // Lý do ban (hiển thị cho user khi login)
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  jobs               Job[]
  accounts           Account[]
  sessions           Session[]
  likes              Like[]
  creditTransactions CreditTransaction[]
  posts              Post[]
}


// =============================================
// JOB - Lịch sử gen ảnh
// =============================================
model Job {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  featureId   String
  feature     Feature  @relation(fields: [featureId], references: [id])
  featureSlug String   // Cache slug để query nhanh
  featureName String   // Cache tên để hiển thị không cần join

  // Prompt thực tế sử dụng (có thể khác prompt gốc nếu custom)
  promptUsed  String   @db.Text

  // Ảnh
  inputUrls   String[] // URL ảnh input đã upload lên R2 (1 hoặc 2)
  outputUrl   String?  // URL ảnh output kết quả

  // Thông số gen
  quality     String   @default("sd")   // "sd" hoặc "hd"
  width       Int      @default(1024)
  height      Int      @default(1536)
  orientation String   @default("portrait") // "portrait", "landscape", "square"

  // Trạng thái
  status          String   @default("pending") // "pending", "processing", "done", "failed"
  errorMsg        String?  // Thông báo lỗi nếu failed
  chainhubTaskId  String?  // ChainHub task_id để poll status async

  // Credits
  creditUsed  Int      @default(1)

  // Gallery settings
  isPublic    Boolean  @default(true) // Hiển thị trong gallery công khai
  title       String?  // User có thể đặt tiêu đề cho ảnh

  // Metadata
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  likes       Like[]

  @@index([userId])
  @@index([featureId])
  @@index([featureSlug])
  @@index([status])
  @@index([isPublic, status, createdAt])
  @@index([userId, createdAt])
}

// =============================================
// LIKE - Lượt thích ảnh trong Gallery
// =============================================
model Like {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  jobId     String
  job       Job      @relation(fields: [jobId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([userId, jobId]) // Mỗi user chỉ like 1 lần mỗi ảnh
  @@index([jobId])
  @@index([userId])
}

// =============================================
// CREDIT TRANSACTION - Lịch sử credits
// =============================================
model CreditTransaction {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  amount      Int      // Số credits (dương = thêm vào, âm = trừ đi)
  type        String   // "earn" | "spend" | "purchase" | "bonus"
  description String   // Mô tả: "Đăng ký mới", "Tạo ảnh: Thay áo", "Mua 100 credits"
  usdAmount   Float?   // Số tiền USD thực tế (chỉ có với type=purchase)

  jobId       String?  // Liên kết đến Job nếu là spend
  stripePaymentIntentId String? // Liên kết Stripe nếu là purchase

  createdAt   DateTime @default(now())

  @@index([userId])
  @@index([userId, createdAt])
  @@index([type])
}

// =============================================
// NEXTAUTH - Account & Session
// =============================================
model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// =============================================
// BLOG - Bài viết / Tin tức
// =============================================
model Post {
  id          String   @id @default(cuid())
  slug        String   @unique
  title       String
  excerpt     String?  @db.Text
  content     String   @db.Text
  coverImage  String?
  published   Boolean  @default(false)
  
  authorId    String
  author      User     @relation(fields: [authorId], references: [id])
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([slug])
  @@index([published, createdAt])
}

// =============================================
// PASSWORD RESET TOKEN - Đặt lại mật khẩu
// =============================================
model PasswordResetToken {
  id         String   @id @default(cuid())
  email      String
  token      String   @unique
  expires    DateTime
  createdAt  DateTime @default(now())

  @@unique([email, token])
  @@index([email])
}


// =============================================
// AUDIT LOG - Nhật ký hành động admin
// =============================================
model AuditLog {
  id          String   @id @default(cuid())
  action      String   // "ban_user", "unban_user", "delete_user", "update_role", "gift_credits", etc.
  actorId     String   // Admin/Staff who performed the action
  actorEmail  String   // Cached for display
  targetType  String   // "user", "job", "feature", "blog"
  targetId    String?  // ID of the affected record
  targetLabel String?  // Human-readable label (e.g., user email, feature name)
  details     String?  @db.Text // JSON string with additional details
  createdAt   DateTime @default(now())

  @@index([action])
  @@index([actorId])
  @@index([createdAt])
}
